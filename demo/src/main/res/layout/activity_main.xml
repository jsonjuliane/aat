<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textSizeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/text_size" />

            <TextView
                android:id="@+id/textSizeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="100%"
                android:textStyle="bold" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/textSizeSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <Switch
            android:id="@+id/highContrastSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/high_contrast" />

        <TextView
            android:id="@+id/fontStyleLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/font_style" />

        <RadioGroup
            android:id="@+id/fontStyleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/fontSansRadio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/font_sans" />

            <RadioButton
                android:id="@+id/fontMonoRadio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/font_mono" />
        </RadioGroup>

        <TextView
            android:id="@+id/languageLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/language" />

        <RadioGroup
            android:id="@+id/languageGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/languageEnRadio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/language_en" />

            <RadioButton
                android:id="@+id/languageEsRadio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/language_es" />
        </RadioGroup>

        <TextView
            android:id="@+id/body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/main_body" />

        <Button
            android:id="@+id/readAloudButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/read_aloud"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/openSecondButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/open_second_screen"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>

